<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Empty theme that defers to MaterialTheme inside the Compose tree.
        We use a translucent system bar so Compose Material3 owns the look.
    -->
    <style name="Theme.ComfyMobileClient" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
